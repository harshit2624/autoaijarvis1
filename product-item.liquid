            <script type="application/json" data-quick-add-variants="{{ quick_add_id }}">
              [
                {%- for variant in card_product.variants -%}
                  {
                    "id": {{ variant.id | json }},
                    "available": {{ variant.available | json }},
                    "price": {{ variant.price | money | json }},
                    "option1": {{ variant.option1 | json }},
                    "option2": {{ variant.option2 | json }},
                    "option3": {{ variant.option3 | json }},
                    "title": {{ variant.title | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              ]
            </script>
            <script>
              (function () {
                if (window.__qaInit) return;
                window.__qaInit = true;

                // Confirmed theme behavior (via Sidekick audit of snippets/minicart.liquid
                // + assets/global.js): the minicart HTML is rendered once at page load and
                // never re-fetched. Only 3 things need manual updating after an AJAX add —
                // the cart-count badges, the free-shipping bar, and the header total — then
                // the drawer is opened by simulating a click on the real cart icon trigger.
                function refreshCartUIAndOpenDrawer() {
                  fetch('/cart.json')
                    .then(function (res) { return res.json(); })
                    .then(function (cart) {
                      document.querySelectorAll('.cart-count').forEach(function (el) {
                        el.innerHTML = el.classList.contains('cart-count-drawer')
                          ? '(' + cart.item_count + ')'
                          : (cart.item_count > 100 ? '~' : cart.item_count);
                      });
                      try {
                        var freeShip = document.querySelector('free-ship-progress-bar');
                        if (freeShip && typeof freeShip.init === 'function') freeShip.init(cart.items_subtotal_price);
                      } catch (e) {}
                      try {
                        var headerTotal = document.querySelector('header-total-price');
                        if (headerTotal && typeof headerTotal.updateTotal === 'function') headerTotal.updateTotal(cart);
                      } catch (e) {}
                    })
                    .catch(function () {})
                    .finally(function () {
                      try {
                        var cartIcon = document.querySelector('#cart-icon-bubble');
                        if (cartIcon) cartIcon.click();
                      } catch (e) {}
                      // Future-proofing: nothing subscribes to this yet, but publish it
                      // in case the theme adds a minicart listener later.
                      try {
                        if (typeof window.publish === 'function') {
                          window.publish('cart-update', { source: 'quick-add' });
                        }
                      } catch (e) {}
                    });
                }

                document.addEventListener('DOMContentLoaded', function () {
                  // Open
                  document.querySelectorAll('[data-quick-add-open]').forEach(function (trigger) {
                    trigger.addEventListener('click', function (e) {
                      e.preventDefault();
                      e.stopPropagation();
                      var id = trigger.getAttribute('data-quick-add-open');
                      var modal = document.getElementById(id);
                      if (modal) {
                        modal.classList.add('is-open');
                        document.body.classList.add('quick-add-lock-scroll');
                      }
                    });
                  });

                  // Close (backdrop or × button)
                  document.querySelectorAll('[data-quick-add-close]').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                      var modal = btn.closest('.quick-add');
                      if (modal) modal.classList.remove('is-open');
                      document.body.classList.remove('quick-add-lock-scroll');
                    });
                  });

                  // Wire up each modal's variant picker + add-to-cart
                  document.querySelectorAll('.quick-add').forEach(function (modal) {
                    var id = modal.id;
                    var dataScript = document.querySelector('[data-quick-add-variants="' + id + '"]');
                    var variants = [];
                    try { variants = JSON.parse(dataScript.textContent); } catch (e) {}

                    var optionCount = modal.querySelectorAll('.quick-add__option-group').length;
                    var selections = [];
                    var submitBtn = modal.querySelector('[data-quick-add-submit]');
                    var submitLabel = modal.querySelector('[data-quick-add-submit-label]');
                    var statusEl = modal.querySelector('[data-quick-add-status]');
                    var priceEl = modal.querySelector('[data-quick-add-price]');
                    var activeVariant = optionCount === 0 && variants.length ? variants[0] : null;

                    function findMatch() {
                      if (optionCount === 0) return variants[0] || null;
                      if (selections.length !== optionCount || selections.indexOf(undefined) !== -1) return null;
                      return variants.find(function (v) {
                        return [v.option1, v.option2, v.option3].slice(0, optionCount).every(function (val, i) {
                          return val === selections[i];
                        });
                      }) || null;
                    }

                    function updateUI() {
                      var match = optionCount === 0 ? activeVariant : findMatch();
                      if (match) {
                        submitBtn.disabled = !match.available;
                        submitLabel.textContent = match.available ? 'Add to Cart' : 'Sold Out';
                        if (priceEl && match.price) priceEl.textContent = match.price;
                        submitBtn.dataset.variantId = match.id;
                      } else {
                        submitBtn.disabled = true;
                        submitLabel.textContent = 'Select an option';
                        delete submitBtn.dataset.variantId;
                      }
                    }

                    modal.querySelectorAll('.quick-add__option-value').forEach(function (btn) {
                      btn.addEventListener('click', function () {
                        var idx = parseInt(btn.dataset.optionIndex, 10);
                        var group = btn.closest('.quick-add__option-group');
                        group.querySelectorAll('.quick-add__option-value').forEach(function (b) { b.classList.remove('is-selected'); });
                        btn.classList.add('is-selected');
                        selections[idx] = btn.dataset.value;
                        updateUI();
                      });
                    });

                    if (submitBtn) {
                      submitBtn.addEventListener('click', function () {
                        var variantId = submitBtn.dataset.variantId;
                        if (!variantId) return;
                        submitBtn.disabled = true;
                        if (statusEl) statusEl.textContent = 'Adding…';
                        fetch('/cart/add.js', {
                          method: 'POST',
                          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                          body: JSON.stringify({ id: variantId, quantity: 1 }),
                        })
                          .then(function (res) { if (!res.ok) throw new Error('add failed'); return res.json(); })
                          .then(function () {
                            if (statusEl) statusEl.innerHTML = '✓ Added to cart — <a href="/cart">View Cart</a>';
                            refreshCartUIAndOpenDrawer();
                            setTimeout(function () {
                              modal.classList.remove('is-open');
                              document.body.classList.remove('quick-add-lock-scroll');
                              if (statusEl) statusEl.textContent = '';
                              submitBtn.disabled = false;
                            }, 2500);
                          })
                          .catch(function () {
                            if (statusEl) statusEl.textContent = 'Could not add to cart — please try again.';
                            submitBtn.disabled = false;
                          });
                      });
                    }

                    updateUI();
                  });
                });
              })();
            </script>
