# ═══════════════════════════════════════════════════════════
#  JARVIS × Shopify — Environment Variables
#  Copy to .env for local dev. Add these in Render dashboard
#  for production (never commit .env to git).
# ═══════════════════════════════════════════════════════════

# ── Shopify ─────────────────────────────────────────────────
# Your store name — ONLY the part before .myshopify.com
# e.g. for  mystore.myshopify.com  →  SHOP_NAME=mystore
SHOP_NAME=your-store-name

# From: Shopify Dev Dashboard → Your App → Settings
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# ── CORS ────────────────────────────────────────────────────
# Comma-separated frontend URLs allowed to call this server.
# Use * for development. Restrict to your domain in production.
# e.g. https://jarvis.netlify.app,https://yourdomain.com
ALLOWED_ORIGINS=*

# ── Server ──────────────────────────────────────────────────
# Render sets PORT automatically — leave as 10000 locally
PORT=3001
